# Copy this file to .env or your shell profile and fill in local values.
# Never commit real API keys, chat IDs, account balances, or broker exports.

ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
FRED_API_KEY=
FINNHUB_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TELEGRAM_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALMANAC_API_KEY=
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_ALMANAC_API_KEY=

# Optional private employee-share plan settings. Defaults remain disabled.
ALMANAC_ESPP_TICKER=9999.T
ALMANAC_ESPP_MONTHLY_AMOUNT_JPY=0
ALMANAC_ESPP_EMPLOYEE_AMOUNT_JPY=0
ALMANAC_ESPP_BONUS_AMOUNT_JPY=0
ALMANAC_ESPP_INCENTIVE_RATE=0

# JSON array of private recurring cash-flow definitions. Leave empty to disable.
# Example shape: [{"id":"sample","label":"Sample","amount":10000,"currency":"JPY","cadence":"monthly","day_of_month":1,"broker":"sample"}]
ALMANAC_CONTRIBUTION_SCHEDULE_JSON=

# Measurement hygiene: ignore NAV history before the accounting fixes stabilized.
ALMANAC_CLEAN_NAV_SINCE=2026-05-25
ALMANAC_MIN_CLEAN_DAYS=20
