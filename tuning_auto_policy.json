    "max_short_positions": "high",
    "currency_usd_target_pct": "medium",
    "currency_jpy_target_pct": "medium",
    "sector_max_pct": "medium",
    "sector_rebalance_threshold_pct": "medium",
    "macro_cache_hours": "low",
