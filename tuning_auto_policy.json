{
  "version": 2,
  "auto_apply_allowlist": [
    "recovery_window_days",
    "currency_usd_target_pct",
    "currency_jpy_target_pct",
    "sector_max_pct",
    "sector_rebalance_threshold_pct",
    "max_short_positions",
    "macro_cache_hours",
    "geopolitical_cache_hours",
    "price_cache_minutes",
    "news_articles_per_ticker"
  ],
